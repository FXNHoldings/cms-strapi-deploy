# Copy to .env and fill in real values. DO NOT commit .env to git.

# ---------- Database ----------
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=change-me-to-a-long-random-string

# ---------- Strapi secrets (generate with ./scripts/generate-secrets.sh) ----------
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me

# ---------- AI Writer plugin (Claude Sonnet 4.5) ----------
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Autopost worker ----------
# Create this token in Strapi admin after first boot:
# Settings → API Tokens → Create new API Token → Type: Full access
AUTOPOST_STRAPI_TOKEN=paste-full-access-token-here
