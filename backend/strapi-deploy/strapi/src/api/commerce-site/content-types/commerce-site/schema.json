{
  "kind": "collectionType",
  "collectionName": "commerce_sites",
  "info": {
    "singularName": "commerce-site",
    "pluralName": "commerce-sites",
    "displayName": "Commerce · Site",
    "description": "Websites/channels that can consume shared commerce products, offers, and deals."
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "name": { "type": "string", "required": true, "maxLength": 120 },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "domain": { "type": "string", "required": true, "maxLength": 180 },
    "niche": { "type": "string", "maxLength": 120 },
    "country": { "type": "string", "maxLength": 2 },
    "currency": { "type": "string", "default": "USD", "maxLength": 8 },
    "enabledCategories": { "type": "json" },
    "siteStatus": {
      "type": "enumeration",
      "enum": ["active", "inactive"],
      "default": "active",
      "required": true
    },
    "deals": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::commerce-deal.commerce-deal",
      "mappedBy": "targetSites"
    }
  }
}
