{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Travel Blog · Category",
    "description": "Top-level content categories (e.g. Flights, Hotels, Destinations, Travel Tips) with unlimited sub-category depth"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true, "maxLength": 80 },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "description": { "type": "text" },
    "icon": { "type": "string", "maxLength": 40 },
    "color": { "type": "string", "maxLength": 20 },
    "order": { "type": "integer", "default": 0 },
    "site": {
      "type": "enumeration",
      "enum": ["all", "travel", "nxt-bargains", "future-1", "future-2"],
      "default": "all",
      "description": "Restrict this category to a specific blog site (leave 'all' for shared)"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "parent"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "category"
    }
  }
}

