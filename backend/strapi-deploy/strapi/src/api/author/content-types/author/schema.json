{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Travel Blog · Author"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true, "maxLength": 120 },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "email": { "type": "email" },
    "bio": { "type": "text" },
    "avatar": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "twitter": { "type": "string" },
    "website": { "type": "string" },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "author"
    }
  }
}
