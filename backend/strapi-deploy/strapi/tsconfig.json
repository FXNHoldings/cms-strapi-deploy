{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "baseUrl": "."
  },
  "include": ["src/plugins/**/admin/**/*", "src/plugins/**/strapi-admin.ts"],
  "exclude": ["node_modules", "build", "dist", ".cache", ".tmp"]
}
